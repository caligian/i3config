set $raise_volume pactl set-sink-volume @DEFAULT_SINK@ +10% && killall -SIGUSR1 i3status 
set $lower_volume pactl set-sink-volume @DEFAULT_SINK@ -10% && killall -SIGUSR1 i3status 
set $mute_volume pactl set-sink-mute @DEFAULT_SINK@ toggle && killall -SIGUSR1 i3status 
set $mute_mic pactl set-source-mute @DEFAULT_SOURCE@ toggle && killall -SIGUSR1 i3status 
set $mod Mod4 
set $ws1 1 
set $ws2 2 
set $ws3 3 
set $ws4 4 
set $ws5 5 
set $ws6 6 
set $ws7 7 
set $ws8 8 
set $ws9 9 
set $ws10 10 
bindsym Mod4+Return exec --no-startup-id xfce4-terminal
bindsym Mod4+Control+f exec --no-startup-id firefox
bindsym Mod4+Control+Return exec --no-startup-id nvim-qt
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10% && killall -SIGUSR1 i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% && killall -SIGUSR1 i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && killall -SIGUSR1 i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && killall -SIGUSR1 i3status
bindsym Mod4+Control+j resize shrink height 10 px or 10 ppt
bindsym Mod4+Control+k resize grow height 10 px or 10 ppt
bindsym Mod4+Control+h resize shrink width 10 px or 10 ppt
bindsym Mod4+Control+l resize grow width 10 px or 10 ppt
bindsym Mod4+Shift+q kill
bindsym Mod4+p exec --no-startup-id dmenu_run   -fn 'Liberation Sans' -nb '#002b36' -sb '#b58900' -sf '#002b36' -b -l 15
bindsym Mod4+Shift+h move left
bindsym Mod4+Shift+j move down
bindsym Mod4+Shift+k move up
bindsym Mod4+Shift+l move right
bindsym Mod4+Shift+space floating toggle
bindsym Mod4+f fullscreen
bindsym Mod4+h focus left
bindsym Mod4+j focus down
bindsym Mod4+k focus up
bindsym Mod4+l focus right
bindsym Mod4+v split v
bindsym Mod4+b split h
bindsym Mod4+s layout stacking
bindsym Mod4+w layout tabbed
bindsym Mod4+e layout toggle split
bindsym Mod4+Shift+e floating toggle
bindsym Mod4+space focus mode_toggle
bindsym Mod4+a focus parent
bindsym Mod4+1 workspace number 1
bindsym Mod4+Shift+1 move container to workspace number 1
bindsym Mod4+2 workspace number 2
bindsym Mod4+Shift+2 move container to workspace number 2
bindsym Mod4+3 workspace number 3
bindsym Mod4+Shift+3 move container to workspace number 3
bindsym Mod4+4 workspace number 4
bindsym Mod4+Shift+4 move container to workspace number 4
bindsym Mod4+5 workspace number 5
bindsym Mod4+Shift+5 move container to workspace number 5
bindsym Mod4+6 workspace number 6
bindsym Mod4+Shift+6 move container to workspace number 6
bindsym Mod4+7 workspace number 7
bindsym Mod4+Shift+7 move container to workspace number 7
bindsym Mod4+8 workspace number 8
bindsym Mod4+Shift+8 move container to workspace number 8
bindsym Mod4+9 workspace number 9
bindsym Mod4+Shift+9 move container to workspace number 9
bindsym Mod4+10 workspace number 10
bindsym Mod4+Shift+10 move container to workspace number 10
bindsym Mod4+Shift+c reload
bindsym Mod4+Shift+r restart
bindsym Mod4+r mode "resize"
exec --no-startup-id setxkbmap -option caps:swapescape
exec --no-startup-id dex -ae i3 -s ~/.config/autostart
focus_follows_mouse no
mouse_warping output
focus_wrapping yes
workspace_auto_back_and_forth yes
focus_on_window_activation none
show_marks yes
ipc-socket ~/.config/i3/i3.socket
default_border pixel 4
default_floating_border pixel 4
hide_edge_borders smart
floating_modifier Mod4
font pango:Sans 13
client.focused #002b36 #002b36 #b58900 #268bd2 #b58900
client.focused_inactive #073642 #073642 #93a1a1 #073642 #073642
client.unfocused #073642 #073642 #657b83 #073642 #073642
client.urgent #d33682 #d33682 #002b36 #d33682 #d33682
client.background #002b36

bar {
    status_command  i3status --config ~/.config/i3status/config
    position bottom
    output primary
    separator_symbol 
    workspace_min_width 1
    colors {
        background #002b36
        statusline #839496
        separator #839496
        focused_workspace #839496 #002b36 #839496
        active_workspace #839496 #839496 #002b36
        inactive_workspace #073642 #073642 #839496
        urgent_workspace #dc322f #dc322f #93a1a1
        binding_mode #b58900 #b58900 #002b36
    }

}
